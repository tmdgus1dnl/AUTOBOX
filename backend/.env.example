# AutoBox Backend Environment Variables
# ============================================
# 사용법: cp .env.example .env && nano .env
# 실행: cd backend && docker-compose up -d --build
# ============================================

# ===========================================
# Database Configuration (필수)
# ===========================================
# Azure MySQL 사용 시
DATABASE_URL=mysql+pymysql://YOUR_USERNAME:YOUR_PASSWORD@YOUR_HOST:3306/YOUR_DATABASE?charset=utf8mb4

# 로컬 MySQL 사용 시 (--profile with-db)
# DATABASE_URL=mysql+pymysql://root:root@mysql:3306/autobox?charset=utf8mb4
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=autobox

# ===========================================
# Backend Configuration
# ===========================================
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ===========================================
# CORS Configuration
# ===========================================
# 개발: http://localhost,http://localhost:80,http://localhost:5173
# 프로덕션: https://your-domain.com
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173

# ===========================================
# Frontend Configuration
# ===========================================
VITE_API_URL=/api/v1

# ===========================================
# MQTT Configuration
# ===========================================
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_TOPIC_PREFIX=autobox
MQTT_CLIENT_ID=autobox-backend
MQTT_USERNAME=backend
MQTT_PASSWORD=your_mqtt_password_here
MQTT_ENABLED=true

# ===========================================
# MQTT TLS Configuration (외부 연결용)
# ===========================================
MQTT_USE_TLS=false
MQTT_CA_CERT=
MQTT_CLIENT_CERT=
MQTT_CLIENT_KEY=
MQTT_TLS_INSECURE=false

# ===========================================
# Raspberry Pi REST API (optional)
# ===========================================
RASPBERRY_PI_URL=http://192.168.0.100:5000






