# AutoBox Raspberry Pi MQTT Configuration

# EC2 MQTT Broker (TLS)
EC2_BROKER_HOST=43.201.254.235
EC2_BROKER_PORT=8883

# MQTT Authentication
MQTT_USERNAME=raspberry-pi
MQTT_PASSWORD=your_password_here

# TLS Certificates
CA_CERT_PATH=/home/pi/autobox/certs/ca.crt
CLIENT_CERT_PATH=
CLIENT_KEY_PATH=

# MQTT Settings
TOPIC_PREFIX=autobox
CLIENT_ID=raspberry-pi-client

# Local Broker (for bridge mode)
LOCAL_BROKER_HOST=localhost
LOCAL_BROKER_PORT=1883

# Device Settings
DEVICE_ID=rpi-001
PUBLISH_INTERVAL=5
